# Art Authentication Agent - Environment Configuration
# Copy this file to .env and fill in your actual credentials

# ======================================
# Microsoft Foundry Configuration
# ======================================
# These are required to run the agent on Microsoft Foundry

FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.ai.azure.com
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o
FOUNDRY_API_KEY=your-foundry-api-key-here

# ======================================
# Azure AI Vision Configuration
# ======================================
# Required for artwork image analysis

AZURE_VISION_ENDPOINT=https://<your-region>.api.cognitive.microsoft.com
AZURE_VISION_KEY=your-vision-api-key-here

# ======================================
# Azure Quantum Configuration (Optional)
# ======================================
# For advanced pattern recognition and high-dimensional analysis

AZURE_QUANTUM_ENDPOINT=https://<your-region>.quantum.azure.com
AZURE_QUANTUM_KEY=your-quantum-api-key-here

# ======================================
# Azure Data Services Configuration
# ======================================
# For provenance database and historical records

AZURE_DATA_ENDPOINT=https://<your-storage-account>.database.windows.net
AZURE_DATA_KEY=your-data-api-key-here
PROVENANCE_DB_CONNECTION=Server=<your-server>.database.windows.net;Database=art_provenance;User Id=<username>;Password=<password>;

# ======================================
# Azure Storage Configuration
# ======================================
# For storing reports and analysis results

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=authentication-reports

# ======================================
# SharePoint Integration
# ======================================
# For sharing reports and provenance documentation

SHAREPOINT_SITE_ID=<your-sharepoint-site-id>
SHAREPOINT_LIST_ID=<your-sharepoint-list-id>
AZURE_TENANT_ID=<your-azure-tenant-id>

# ======================================
# Azure Key Vault
# ======================================
# For secure credential management

AZURE_KEYVAULT_NAME=<your-keyvault-name>
AZURE_KEYVAULT_URL=https://<your-keyvault-name>.vault.azure.net/

# ======================================
# Azure Application Insights (Monitoring)
# ======================================
# For logging and performance monitoring

APPINSIGHTS_INSTRUMENTATION_KEY=<your-appinsights-key>

# ======================================
# Local Development Configuration
# ======================================
# For testing without full Azure setup

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ======================================
# API Configuration (for HTTP server mode)
# ======================================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Art Authentication API
API_VERSION=1.0.0
