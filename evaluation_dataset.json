    "evaluation_metrics": {
      "accuracy": {
        "definition": "Percentage of correct authenticity determinations",
        "target": 0.92,
        "calculation": "correct_predictions / total_samples"
      },
      "false_positive_rate": {
        "definition": "Rate of incorrectly authenticated forgeries (calling forgery authentic)",
        "target": 0.05,
        "calculation": "false_positives / total_forgeries"
      },
      "false_negative_rate": {
        "definition": "Rate of incorrectly rejected authentic artworks",
        "target": 0.03,
        "calculation": "false_negatives / total_authentic"
      },
      "precision": {
        "definition": "Of all items marked authentic, how many are actually authentic",
        "target": 0.95,
        "calculation": "true_positives / (true_positives + false_positives)"
      },
      "recall": {
        "definition": "Of all actual authentic items, how many are identified correctly",
        "target": 0.97,
        "calculation": "true_positives / (true_positives + false_negatives)"
      },
      "f1_score": {
        "definition": "Harmonic mean of precision and recall",
        "target": 0.96,
        "calculation": "2 * (precision * recall) / (precision + recall)"
      }
    },
    "evaluation_procedure": {
      "step_1": "Submit artwork details and image to agent",
      "step_2": "Agent performs vision analysis on image",
      "step_3": "Agent searches provenance records",
      "step_4": "Agent calculates authentication score",
      "step_5": "Compare agent verdict with ground truth",
      "step_6": "Record metric results",
      "step_7": "Aggregate results across all test cases",
      "step_8": "Generate evaluation report"
    },
    "notes": "This dataset is designed for developmental and testing purposes. For production evaluation, additional test cases and diverse artwork styles should be included. Success metrics should be reviewed quarterly as the agent learns from more authentication cases."
  }
